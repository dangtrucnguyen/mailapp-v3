{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MailApp",
  "version": "3.0.0-beta.1",
  "identifier": "fr.scingenierie.mailapp",
  "build": {
    "frontendDist": "../static/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MailApp — SCIngenierie",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://op13.scigroup.fr http://192.168.1.242:* http://localhost:*; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "providerShortName": "SCIngenierie",
      "signingIdentity": null
    },
    "createUpdaterArtifacts": true,
    "resources": []
  }
}
